<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>發文 - BLGG</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="container">
    <div class="sidebar">
      <a href="/" class="logo">
        <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>
      <a href="/" class="nav-link">🏠 首頁</a>
      <a href="/public" class="nav-link">🌐 公共貼文</a>
      <a href="/search" class="nav-link">🔍 搜尋好友</a>
      <a href="/profile" class="nav-link">👤 個人資料</a>
      <a href="/logout" class="nav-link">🚪 登出</a>
      <button class="theme-toggle" onclick="document.body.classList.toggle('dark')">🌙</button>
    </div>
    <div class="main">
      <div class="header">
        <h1>發文</h1>
      </div>
      <div style="padding: 15px;">
        <form action="/posts" method="POST">
          <input type="text" name="title" class="form-input" placeholder="標題" required>
          <textarea name="content" class="form-input" placeholder="有什麼新鮮事？" style="min-height: 150px; margin-top: 10px;" required></textarea>
          <div class="checkbox">
            <input type="checkbox" name="is_public" id="is_public" checked>
            <label for="is_public" style="display: inline; color: #536471;">公開貼文</label>
          </div>
          <button type="submit" class="btn-twitter" style="margin-top: 15px; width: auto; padding: 10px 20px;">推文</button>
        </form>
      </div>
    </div>
  </div>
</body>
</html>