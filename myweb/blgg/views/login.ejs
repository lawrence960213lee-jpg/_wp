<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>登入 - BLGG</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="container">
    <div class="sidebar">
      <a href="/" class="logo">
        <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>
      <a href="/" class="nav-link">🏠 首頁</a>
      <a href="/register" class="nav-link">📝 註冊</a>
      <button class="theme-toggle" onclick="document.body.classList.toggle('dark')">🌙</button>
    </div>
    <div class="main">
      <div class="auth-container">
        <h1>登入 BLGG</h1>
        <form action="/login" method="POST">
          <input type="text" name="username" class="form-input" placeholder="帳號" required>
          <input type="password" name="password" class="form-input" placeholder="密碼" required>
          <button type="submit" class="btn-twitter">登入</button>
        </form>
        <div class="link-bar">
          <span>還沒有帳號？</span>
          <a href="/register">註冊</a>
        </div>
      </div>
    </div>
  </div>
</body>
</html>